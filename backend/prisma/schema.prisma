generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SensorLog {

  id Int @id @default(autoincrement())

  // =========================
  // SENSORES
  // =========================

  temp Float

  hum Float

  dist Float

  flame Int

  light Int


  // =========================
  // ALERTAS
  // =========================

  fire Int

  intrusion Int

  temp_alert Int

  high_hum Int

  low_light Int

  any_alert Int


  // =========================
  // METADATA
  // =========================

  source String

  createdAt DateTime @default(now())
}