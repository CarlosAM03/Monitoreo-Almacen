generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SensorLog {
  id        Int      @id @default(autoincrement())
  temp      Float
  hum       Float
  gas       Float
  flame     Int
  mov       Int
  dist      Float
  source    String
  createdAt DateTime @default(now())
}